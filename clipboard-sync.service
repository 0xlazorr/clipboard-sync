[Unit]
Description=Clipboard Sync Daemon (Linux to Android)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 %h/Documents/clipboard-sync/linux_sync.py
Restart=on-failure
RestartSec=5
# Environment variables ensure GUI clipboard utilities can interface with the correct display server
Environment=DISPLAY=:0
Environment=WAYLAND_DISPLAY=wayland-0

[Install]
WantedBy=default.target
